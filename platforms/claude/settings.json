{
  "includeCoAuthoredBy": false,
  "model": "sonnet",
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "permissions": {
    "allow": [
      "Bash(.venv/bin/*)",
      "Bash(make:*)",
      "Bash(ci-platform-manager:*)",
      "Bash(git:*)",
      "Bash(python3:*)",
      "Bash(open:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(jq:*)",
      "Bash(codex:*)",
      "Bash(timeout:*)",
      "Bash(script:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(env:*)",
      "Bash(go:*)",
      "Bash(curl:*)",
      "Bash(gh:*)",
      "Bash(sqlite3:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(ln:*)",
      "Bash(chmod:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(tee:*)",
      "Bash(xargs:*)",
      "Bash(printf:*)",
      "Bash(diff:*)",
      "Bash(column:*)",
      "Bash(which:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(less:*)",
      "Bash(ps:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(tar:*)",
      "Bash(date:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(~/.claude/scripts/codex-pipe:*)",
      "Read(/tmp/**)"
    ],
    "additionalDirectories": [
      "~/work",
      "~/projects",
      "~/.config",
      "~/.claude"
    ]
  }
}
