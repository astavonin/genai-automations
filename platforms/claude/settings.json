{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(.venv/bin/*)",
      "Bash(make:*)",
      "Bash(projctl:*)",
      "Bash(git:*)",
      "Bash(python3:*)",
      "Bash(open:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(jq:*)",
      "Bash(codex:*)",
      "Bash(timeout:*)",
      "Bash(script:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(env:*)",
      "Bash(go:*)",
      "Bash(curl:*)",
      "Bash(gh:*)",
      "Bash(sqlite3:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(ln:*)",
      "Bash(chmod:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(tee:*)",
      "Bash(xargs:*)",
      "Bash(printf:*)",
      "Bash(diff:*)",
      "Bash(column:*)",
      "Bash(which:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(less:*)",
      "Bash(ps:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(tar:*)",
      "Bash(date:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(bash:*)",
      "Bash(xdg-open:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(readelf:*)",
      "Bash(xxd:*)",
      "Bash(strace:*)",
      "Bash(lsof:*)",
      "Bash(ip:*)",
      "Bash(ffprobe:*)",
      "Bash(ffmpeg:*)",
      "Bash(shellcheck:*)",
      "Bash(yamllint:*)",
      "Bash(pipx:*)",
      "Bash(~/.local/bin/projctl:*)",
      "Bash(projctl:*)",
      "Bash(~/.claude/scripts/codex-pipe:*)",
      "Bash(adb:*)",
      "Bash(fastboot:*)",
      "Bash(aapt:*)",
      "Bash(aapt2:*)",
      "Bash(apksigner:*)",
      "Bash(zipalign:*)",
      "Bash(avdmanager:*)",
      "Bash(emulator:*)",
      "Bash(sdkmanager:*)",
      "Read(/tmp/**)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "~/work",
      "~/projects",
      "~/.config",
      "~/.claude"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(projctl create*)",
            "command": "jq -r 'if ((.tool_response.output // \"\") | (contains(\"Created Issues\") and contains(\"work_items/\"))) then {\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"projctl create completed — update the relevant planning/status.md with the new issue number(s) shown above.\"}} | tojson else empty end' 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PostCompact\",\"additionalContext\":\"Compaction just completed. Immediately invoke /refresh to reload behavioral configuration files (CLAUDE.md and all referenced skill files) before responding to the user.\"}}'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "skipAutoPermissionPrompt": true
}
